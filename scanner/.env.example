# --- Postgres ---
POSTGRES_USER=tally
POSTGRES_PASSWORD=tally
POSTGRES_DB=tally_scanner
POSTGRES_PORT=5432
DATABASE_URL=postgresql://tally:tally@localhost:5432/tally_scanner
# Browser GUI (Adminer): http://localhost:8081
ADMINER_PORT=8081

# --- Timezone (used by optional bundled-n8n profile) ---
TZ=America/Vancouver
# Bundled n8n is OFF by default — use your existing n8n app.
# Only needed if you run: docker compose --profile bundled-n8n up -d
N8N_PORT=5678
N8N_HOST=localhost
N8N_PROTOCOL=http
N8N_WEBHOOK_URL=http://localhost:5678/

# --- Scanner worker ---
SCANNER_PORT=8000
# Dry-run skips Anthropic + Notion (filter/dedup only)
SCANNER_DRY_RUN=false

# --- OpenAI (AI filter agent) ---
OPENAI_API_KEY=
OPENAI_FILTER_MODEL=gpt-4o-mini

# --- Anthropic (LLM scorer) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# --- Notion ---
# Create an integration at https://www.notion.so/my-integrations
# Share the scanner DB with that integration.
NOTION_TOKEN=
# Parent page for creating the scanner database (from handoff):
NOTION_PARENT_PAGE_ID=37272d09-0a44-80ec-a852-000b049519b1
# Set after first run creates the DB (or create manually and paste id):
NOTION_DATABASE_ID=

# --- Optional SearXNG (docker compose --profile searxng up) ---
SEARXNG_PORT=8080
SEARXNG_URL=http://localhost:8080
